# ─────────────────────────────────────────────────────────────
# Urban Cairn — environment variables
# Copy this file to ".env" and paste your real values after each "=".
# The real ".env" is gitignored — keys are NEVER committed.
# After editing ".env", run:  npm run deploy   (rebuilds + publishes)
# ─────────────────────────────────────────────────────────────

# 1) Google Analytics 4 — "how many visitors, where from, which pages"
#    Get at: https://analytics.google.com  → Admin → Data Streams → Web → "Measurement ID"
#    Looks like: G-XXXXXXXXXX
VITE_GA_ID=

# 2) Microsoft Clarity — FREE session recordings + heatmaps ("kisne kya dekha")
#    Get at: https://clarity.microsoft.com  → New project → Settings → "Clarity tag" ID
#    Looks like: abcd1234ef  (10-char project id)
VITE_CLARITY_ID=

# 3-5) EmailJS — sends every contact-form lead to your Gmail inbox
#    Get at: https://www.emailjs.com  (free plan)
#    - Add an Email Service (connect urbancairn1@gmail.com)  → Service ID
#    - Create an Email Template with these variables:
#        {{from_name}} {{from_phone}} {{from_email}} {{business_type}} {{interest}} {{message}}
#      Set the template "To email" to:  urbancairn1@gmail.com   → Template ID
#    - Account → API Keys → Public Key
VITE_EMAILJS_SERVICE=
VITE_EMAILJS_TEMPLATE=
VITE_EMAILJS_PUBLIC=

# 6) Calendly — optional: live call-booking embed on the site
#    Get at: https://calendly.com  → your event link
#    Looks like: https://calendly.com/your-name/30min
VITE_CALENDLY_URL=
